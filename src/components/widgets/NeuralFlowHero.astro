---
// Cyberpunk Hero — mirrors homepage aesthetic:
// synthwave grid + warm sun + CRT scanlines + terminal frame + gradient name
export interface Props {
  kicker?: string;
  title: string;
  subtitle?: string;
  subtitleZh?: string;
  height?: string;
  terminalPath?: string;
}
const {
  kicker = 'WONDERLAND OS',
  title,
  subtitle,
  subtitleZh,
  height = 'clamp(420px, 64vh, 620px)',
  terminalPath = '~/wonderland',
} = Astro.props;
const uid = Math.random().toString(36).slice(2, 9);
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700;800&family=IBM+Plex+Mono:wght@300;400;500&family=Instrument+Serif:ital@0;1&display=swap"
  rel="stylesheet"
/>

<section class={`cy-hero cy-${uid}`} style={`--cy-height: ${height}`}>
  <!-- synthwave grid floor -->
  <div class="cy-grid-floor">
    <div class={`cy-grid-inner`} id={`cyGrid-${uid}`}></div>
  </div>
  <!-- warm sun -->
  <div class="cy-sun"></div>
  <div class="cy-sun-slits"></div>
  <!-- overlays -->
  <div class="cy-scanlines"></div>
  <div class="cy-vignette"></div>

  <!-- top meta -->
  <div class="cy-meta">
    <span class="dot"></span>
    <b>{kicker}</b>
  </div>

  <!-- terminal title card -->
  <div class="cy-terminal">
    <div class="cy-term-head">
      <span>{terminalPath} — zsh</span>
      <span>▢ ▢ ◯</span>
    </div>
    <div class="cy-term-body">
      <h1 class="cy-title" set:html={title} />
      {subtitle && <div class="cy-sub"><span class="prompt">$</span> <span set:html={subtitle} /></div>}
      {subtitleZh && <div class="cy-sub-zh" set:html={subtitleZh} />}
    </div>
  </div>
</section>

<style define:vars={{ heightVar: height }}>
  .cy-hero {
    position: relative;
    width: 100%;
    height: var(--heightVar);
    overflow: hidden;
    background: #05050b;
    color: #d1fff0;
    isolation: isolate;
  }

  /* synthwave grid floor */
  .cy-grid-floor {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 60%;
    perspective: 600px;
    pointer-events: none;
    z-index: 0;
  }
  .cy-grid-inner {
    position: absolute;
    left: -20%;
    right: -20%;
    top: 0;
    bottom: 0;
    background-image:
      linear-gradient(#ff2a6d 1px, transparent 1px),
      linear-gradient(90deg, #05d9e8 1px, transparent 1px);
    background-size: 80px 80px;
    transform: rotateX(62deg);
    opacity: 0.55;
    animation: cyGridScroll 2.5s linear infinite;
    mask-image: linear-gradient(180deg, transparent 0%, #000 30%, #000 90%, transparent 100%);
    -webkit-mask-image: linear-gradient(180deg, transparent 0%, #000 30%, #000 90%, transparent 100%);
  }
  @keyframes cyGridScroll {
    from { background-position: 0 0, 0 0; }
    to { background-position: 0 80px, 0 0; }
  }

  /* warm sun */
  .cy-sun {
    position: absolute;
    left: 50%;
    top: 42%;
    width: 380px;
    height: 380px;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, #ffe066 0%, #ff6d2a 25%, #ff2a6d 50%, transparent 70%);
    filter: blur(4px);
    opacity: 0.8;
    pointer-events: none;
    z-index: 0;
  }
  .cy-sun-slits {
    position: absolute;
    left: 50%;
    top: 42%;
    width: 380px;
    height: 380px;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    background: repeating-linear-gradient(0deg, #05050b 0 3px, transparent 3px 14px);
    opacity: 0.55;
    pointer-events: none;
    mix-blend-mode: multiply;
    mask-image: linear-gradient(0deg, #000 30%, transparent 100%);
    -webkit-mask-image: linear-gradient(0deg, #000 30%, transparent 100%);
    z-index: 0;
  }

  /* CRT scanlines + vignette */
  .cy-scanlines {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background-image: repeating-linear-gradient(0deg, rgba(5, 217, 232, 0.06) 0 1px, transparent 1px 3px);
  }
  .cy-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background: radial-gradient(ellipse at center, transparent 55%, rgba(0, 0, 0, 0.75) 100%);
  }

  /* top meta */
  .cy-meta {
    position: absolute;
    top: 22px;
    left: 28px;
    z-index: 5;
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.22em;
    color: rgba(255, 255, 255, 0.55);
    text-transform: uppercase;
    mix-blend-mode: difference;
  }
  .cy-meta .dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: #05d9e8;
    box-shadow: 0 0 12px #05d9e8;
    animation: cyPulse 2s ease-in-out infinite;
  }
  .cy-meta b { color: #fff; font-weight: 500; letter-spacing: 0.22em; }
  @keyframes cyPulse {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }

  /* terminal card */
  .cy-terminal {
    position: absolute;
    left: 50%;
    top: 52%;
    transform: translate(-50%, -50%);
    z-index: 4;
    width: min(640px, 92%);
    border: 1px solid rgba(5, 217, 232, 0.45);
    background: rgba(5, 5, 11, 0.6);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    box-shadow: 0 0 0 1px rgba(255, 42, 109, 0.25), 0 0 60px rgba(5, 217, 232, 0.25);
  }
  .cy-term-head {
    padding: 8px 12px;
    border-bottom: 1px solid rgba(5, 217, 232, 0.25);
    display: flex;
    justify-content: space-between;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: #05d9e8;
    letter-spacing: 0.2em;
  }
  .cy-term-body {
    padding: 30px 28px 26px;
    text-align: center;
  }

  /* gradient animated title (multi-color like homepage name) */
  .cy-title {
    margin: 0 0 14px;
    font-family: 'Instrument Serif', 'Times New Roman', serif;
    font-weight: 400;
    font-size: clamp(40px, 7vw, 80px);
    line-height: 0.98;
    letter-spacing: -0.015em;
    color: #f7f7f0;
    background: linear-gradient(90deg, #ff2bd6 0%, #ffea3a 25%, #4dc5ff 50%, #9effb2 75%, #ff2bd6 100%);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: cyGrad 6s linear infinite;
    text-wrap: balance;
  }
  @keyframes cyGrad {
    0% { background-position: 0% 0%; }
    100% { background-position: 200% 0%; }
  }
  .cy-title em {
    font-style: italic;
    -webkit-text-fill-color: transparent;
  }

  /* tagline */
  .cy-sub {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    letter-spacing: 0.1em;
    color: #9ef5e5;
    margin-top: 6px;
    line-height: 1.5;
  }
  .cy-sub .prompt { color: #ff2a6d; margin-right: 4px; }
  .cy-sub-zh {
    margin-top: 6px;
    font-family: 'Noto Serif SC', 'PingFang SC', serif;
    font-size: 12.5px;
    color: rgba(180, 210, 230, 0.55);
    letter-spacing: 0.04em;
  }

  @media (max-width: 720px) {
    .cy-meta { top: 14px; left: 16px; font-size: 9px; }
    .cy-sun { width: 280px; height: 280px; }
    .cy-sun-slits { width: 280px; height: 280px; }
  }
</style>
