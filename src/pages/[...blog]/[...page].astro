---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';

import Layout from '~/layouts/PageLayout.astro';
import BlogList from '~/components/blog/List.astro';
import Pagination from '~/components/blog/Pagination.astro';
import NeuralFlowHero from '~/components/widgets/NeuralFlowHero.astro';

import { blogListRobots, getStaticPathsBlogList } from '~/utils/blog';

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
  return await getStaticPathsBlogList({ paginate });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page } = Astro.props as Props;
const currentPage = page.currentPage ?? 1;

const metadata = {
  title: `Blog${currentPage > 1 ? ` — Page ${currentPage}` : ''}`,
  robots: {
    index: blogListRobots?.index && currentPage === 1,
    follow: blogListRobots?.follow,
  },
  openGraph: {
    type: 'blog',
  },
};
---

<Layout metadata={metadata}>
  <NeuralFlowHero
    kicker="NEURAL FLOW · BLOG"
    title={`WonderLand <em>Notebook</em>`}
    subtitle="Research, AI, biology — and the strange tissue between them."
    subtitleZh="研究、AI、生命，以及它们之间那些奇异的组织。"
  />

  <div class="nf-continue">
    <!-- Ambient decorative backdrop: HUD marks + floating nodes -->
    <div class="nf-amb" aria-hidden="true">
      <svg class="nf-amb-svg" viewBox="0 0 1200 1600" preserveAspectRatio="xMidYMid slice">
        <defs>
          <radialGradient id="nfDot" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#5fd3ff" stop-opacity="0.9" />
            <stop offset="100%" stop-color="#5fd3ff" stop-opacity="0" />
          </radialGradient>
          <pattern id="nfGrid" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse">
            <path d="M 80 0 L 0 0 0 80" fill="none" stroke="rgba(95,211,255,0.05)" stroke-width="1"/>
          </pattern>
        </defs>
        <rect width="1200" height="1600" fill="url(#nfGrid)" />
        <!-- drifting nodes -->
        <g class="nf-nodes">
          <circle cx="120" cy="200" r="2.5" fill="url(#nfDot)"><animate attributeName="opacity" values="0.2;1;0.2" dur="4s" repeatCount="indefinite"/></circle>
          <circle cx="980" cy="340" r="3" fill="url(#nfDot)"><animate attributeName="opacity" values="0.3;1;0.3" dur="5.5s" repeatCount="indefinite"/></circle>
          <circle cx="60" cy="560" r="2" fill="url(#nfDot)"><animate attributeName="opacity" values="0.1;0.8;0.1" dur="6s" repeatCount="indefinite"/></circle>
          <circle cx="1120" cy="700" r="2.5" fill="url(#nfDot)"><animate attributeName="opacity" values="0.2;0.9;0.2" dur="4.8s" repeatCount="indefinite"/></circle>
          <circle cx="200" cy="900" r="2" fill="url(#nfDot)"><animate attributeName="opacity" values="0.2;0.7;0.2" dur="5s" repeatCount="indefinite"/></circle>
          <circle cx="900" cy="1080" r="3" fill="url(#nfDot)"><animate attributeName="opacity" values="0.3;1;0.3" dur="4.2s" repeatCount="indefinite"/></circle>
          <circle cx="50" cy="1240" r="2" fill="url(#nfDot)"><animate attributeName="opacity" values="0.1;0.8;0.1" dur="5.6s" repeatCount="indefinite"/></circle>
          <circle cx="1080" cy="1400" r="2.5" fill="url(#nfDot)"><animate attributeName="opacity" values="0.2;0.9;0.2" dur="4.4s" repeatCount="indefinite"/></circle>
        </g>
        <!-- schematic diagonal lines -->
        <g stroke="rgba(95,211,255,0.08)" stroke-width="1" fill="none">
          <line x1="0" y1="280" x2="220" y2="180"/>
          <line x1="1020" y1="260" x2="1200" y2="380"/>
          <line x1="0" y1="900" x2="200" y2="820"/>
          <line x1="1100" y1="1200" x2="1200" y2="1280"/>
        </g>
        <!-- HUD crosshair marks at corners -->
        <g stroke="rgba(95,211,255,0.25)" stroke-width="1" fill="none">
          <path d="M 40 40 L 40 60 M 40 40 L 60 40"/>
          <path d="M 1160 40 L 1160 60 M 1160 40 L 1140 40"/>
          <path d="M 40 1560 L 40 1540 M 40 1560 L 60 1560"/>
          <path d="M 1160 1560 L 1160 1540 M 1160 1560 L 1140 1560"/>
        </g>
      </svg>
    </div>

    <section class="nf-listwrap">
      <div class="nf-section-head">
        <span class="bar"></span>
        <span>LATEST · 最新</span>
        <span class="bar"></span>
      </div>
      <BlogList posts={page.data} />
      <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
    </section>
  </div>
</Layout>

<style is:global>
  /* ======== Neural Flow continuation backdrop (brighter twilight) ======== */
  .nf-continue {
    background:
      radial-gradient(ellipse 60% 40% at 10% 5%, rgba(130, 200, 255, 0.22), transparent 60%),
      radial-gradient(ellipse 50% 50% at 92% 25%, rgba(170, 130, 255, 0.16), transparent 65%),
      radial-gradient(ellipse 70% 50% at 50% 90%, rgba(255, 110, 160, 0.10), transparent 70%),
      radial-gradient(ellipse 40% 30% at 85% 70%, rgba(100, 220, 255, 0.14), transparent 60%),
      linear-gradient(180deg, #1a2b52 0%, #1e3260 50%, #17264a 100%);
    min-height: 70vh;
    position: relative;
    color: #e4ecfb;
    overflow: hidden;
  }
  .nf-continue::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: repeating-linear-gradient(
      0deg,
      rgba(95, 211, 255, 0.025) 0 1px,
      transparent 1px 5px
    );
    opacity: 0.5;
    z-index: 0;
  }
  /* ambient decoration layer */
  .nf-amb {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.8;
  }
  .nf-amb-svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  /* slow drift on the whole svg */
  .nf-amb .nf-nodes {
    animation: nfDrift 18s ease-in-out infinite alternate;
    transform-origin: center;
  }
  @keyframes nfDrift {
    0% { transform: translate(0, 0); }
    100% { transform: translate(-12px, 8px); }
  }
  .nf-listwrap {
    position: relative;
    z-index: 1;
    max-width: 760px;
    margin: 0 auto;
    padding: 56px 24px 96px;
  }
  .nf-section-head {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.28em;
    color: rgba(160, 185, 225, 0.55);
    text-transform: uppercase;
    margin-bottom: 40px;
  }
  .nf-section-head .bar {
    flex: 1;
    max-width: 120px;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(95, 211, 255, 0.35),
      transparent
    );
  }

  /* ======== Nuke AstroWind ListItem card, replace with editorial row ======== */
  .nf-continue article {
    display: block !important;
    max-width: none !important;
    margin: 0 !important;
    padding: 0 !important;
    background: transparent !important;
  }
  /* the inner <div> that had bg-white/slate-800 & rounded-xl */
  .nf-continue article > div {
    background: transparent !important;
    border: 0 !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    padding: 0 !important;
    margin: 0 !important;
    transition: none !important;
  }
  /* image block — hidden for editorial simplicity (most posts don't have images anyway) */
  .nf-continue article > a,
  .nf-continue article > div.relative {
    display: none !important;
  }
  .nf-continue article.md\:grid-cols-2 {
    grid-template-columns: none !important;
  }

  /* list row spacing */
  .nf-continue ul { padding: 0; list-style: none; }
  .nf-continue ul > li {
    margin: 0 !important;
    padding: 36px 0 !important;
    border-bottom: 1px solid rgba(95, 211, 255, 0.1);
    transition: padding 0.3s;
  }
  .nf-continue ul > li:first-child { padding-top: 0 !important; }
  .nf-continue ul > li:last-child { border-bottom: none; }
  .nf-continue ul > li:hover {
    padding-left: 8px !important;
  }

  /* meta line (date · author · category) */
  .nf-continue article header .mb-1 {
    font-family: 'JetBrains Mono', ui-monospace, monospace !important;
    font-size: 10px !important;
    letter-spacing: 0.22em !important;
    text-transform: uppercase !important;
    margin-bottom: 14px !important;
  }
  .nf-continue article header .mb-1 span,
  .nf-continue article header .mb-1 time {
    color: rgba(160, 185, 225, 0.7) !important;
    font-size: 10px !important;
  }
  .nf-continue article header .mb-1 a {
    color: #5fd3ff !important;
    text-decoration: none !important;
    border-bottom: 1px dotted rgba(95, 211, 255, 0.4);
    padding-bottom: 1px;
  }
  .nf-continue article header .mb-1 a:hover {
    color: #9fe5ff !important;
    border-bottom-color: #9fe5ff;
  }
  .nf-continue article header .mb-1 svg {
    color: rgba(160, 185, 225, 0.5) !important;
  }

  /* post title — big serif editorial */
  .nf-continue article h2 {
    font-family: 'Instrument Serif', 'Times New Roman', serif !important;
    font-weight: 400 !important;
    font-size: clamp(26px, 3.2vw, 40px) !important;
    line-height: 1.1 !important;
    letter-spacing: -0.015em !important;
    margin: 0 0 14px 0 !important;
    color: #f1f5ff !important;
  }
  .nf-continue article h2 a {
    color: inherit !important;
    text-decoration: none !important;
    transition: color 0.25s, text-shadow 0.25s !important;
    background: none !important;
  }
  .nf-continue article h2 a:hover {
    color: #bfe5ff !important;
    text-shadow: 0 0 18px rgba(95, 211, 255, 0.45);
  }
  .nf-continue article h2 .text-amber-600,
  .nf-continue article h2 [class*='amber'] {
    color: #ffe066 !important;
  }

  /* excerpt — italic serif, subtle */
  .nf-continue article p {
    font-family: 'Instrument Serif', 'Times New Roman', serif !important;
    font-style: italic !important;
    font-size: 18px !important;
    line-height: 1.6 !important;
    color: rgba(210, 220, 245, 0.78) !important;
    margin: 0 !important;
    max-width: 64ch;
  }

  /* tags row — flat, monospace chips */
  .nf-continue article footer {
    margin-top: 16px !important;
  }
  .nf-continue article footer ul {
    display: flex !important;
    flex-wrap: wrap;
    gap: 6px !important;
    padding: 0 !important;
  }
  .nf-continue article footer ul li {
    margin: 0 !important;
    padding: 0 !important;
    border: 0 !important;
  }
  .nf-continue article footer ul li a,
  .nf-continue article footer span {
    display: inline-block !important;
    padding: 3px 8px !important;
    border: 1px solid rgba(95, 211, 255, 0.2) !important;
    border-radius: 2px !important;
    background: rgba(95, 211, 255, 0.04) !important;
    font-family: 'JetBrains Mono', ui-monospace, monospace !important;
    font-size: 10px !important;
    letter-spacing: 0.12em !important;
    text-transform: lowercase !important;
    color: rgba(160, 200, 240, 0.75) !important;
    text-decoration: none !important;
    transition: all 0.2s !important;
  }
  .nf-continue article footer ul li a:hover {
    border-color: #5fd3ff !important;
    color: #9fe5ff !important;
    background: rgba(95, 211, 255, 0.12) !important;
  }

  /* pagination */
  .nf-continue nav[aria-label*='aginat'],
  .nf-continue .pagination {
    margin-top: 56px !important;
    padding-top: 32px !important;
    border-top: 1px solid rgba(95, 211, 255, 0.15) !important;
  }
  .nf-continue nav a,
  .nf-continue .pagination a {
    color: #bfd7ff !important;
    font-family: 'JetBrains Mono', monospace !important;
    font-size: 11px !important;
    letter-spacing: 0.2em !important;
    text-transform: uppercase !important;
  }
  .nf-continue nav a:hover,
  .nf-continue .pagination a:hover {
    color: #5fd3ff !important;
  }

  @media (max-width: 640px) {
    .nf-listwrap { padding: 40px 18px 64px; }
    .nf-continue ul > li { padding: 28px 0 !important; }
    .nf-continue article h2 { font-size: 24px !important; }
    .nf-continue article p { font-size: 16px !important; }
  }
</style>
