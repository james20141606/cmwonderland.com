---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';

import Layout from '~/layouts/PageLayout.astro';
import BlogList from '~/components/blog/List.astro';
import Pagination from '~/components/blog/Pagination.astro';
import NeuralFlowHero from '~/components/widgets/NeuralFlowHero.astro';

import { blogListRobots, getStaticPathsBlogList } from '~/utils/blog';

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
  return await getStaticPathsBlogList({ paginate });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page } = Astro.props as Props;
const currentPage = page.currentPage ?? 1;

const metadata = {
  title: `Blog${currentPage > 1 ? ` — Page ${currentPage}` : ''}`,
  robots: {
    index: blogListRobots?.index && currentPage === 1,
    follow: blogListRobots?.follow,
  },
  openGraph: {
    type: 'blog',
  },
};
---

<Layout metadata={metadata}>
  <NeuralFlowHero
    kicker="NEURAL FLOW · BLOG"
    title={`WonderLand <em>Notebook</em>`}
    subtitle="Research, AI, biology — and the strange tissue between them."
    subtitleZh="研究、AI、生命，以及它们之间那些奇异的组织。"
  />

  <div class="nf-continue">
    <section class="px-6 sm:px-6 py-12 sm:py-16 mx-auto max-w-4xl">
      <BlogList posts={page.data} />
      <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
    </section>
  </div>
</Layout>

<style is:global>
  /* Dark themed continuation — applied to all Neural Flow pages */
  .nf-continue {
    background:
      radial-gradient(ellipse at 10% 0%, rgba(95, 211, 255, 0.04), transparent 50%),
      radial-gradient(ellipse at 90% 20%, rgba(140, 100, 255, 0.03), transparent 60%),
      linear-gradient(180deg, #0a1326 0%, #0c1530 50%, #0a1326 100%);
    min-height: 60vh;
    position: relative;
    color: #d7dff0;
  }
  .nf-continue::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      repeating-linear-gradient(0deg, rgba(95, 211, 255, 0.025) 0 1px, transparent 1px 4px);
    opacity: 0.5;
  }
  /* rewrite AstroWind blog list cards for dark theme */
  .nf-continue h1,
  .nf-continue h2,
  .nf-continue h3,
  .nf-continue h4 {
    color: #f1f5ff !important;
  }
  .nf-continue a {
    color: #bfd7ff;
  }
  .nf-continue a:hover {
    color: #5fd3ff;
  }
  .nf-continue p,
  .nf-continue li,
  .nf-continue span:not(.badge):not(.kicker),
  .nf-continue time {
    color: rgba(210, 220, 245, 0.78);
  }
  .nf-continue article {
    border-bottom: 1px solid rgba(95, 211, 255, 0.12);
    padding-bottom: 2rem;
  }
</style>
