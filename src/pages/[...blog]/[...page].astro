---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';

import Layout from '~/layouts/PageLayout.astro';
import BlogList from '~/components/blog/List.astro';
import Pagination from '~/components/blog/Pagination.astro';
import NeuralFlowHero from '~/components/widgets/NeuralFlowHero.astro';

import { blogListRobots, getStaticPathsBlogList } from '~/utils/blog';

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
  return await getStaticPathsBlogList({ paginate });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page } = Astro.props as Props;
const currentPage = page.currentPage ?? 1;

const metadata = {
  title: `Blog${currentPage > 1 ? ` — Page ${currentPage}` : ''}`,
  robots: {
    index: blogListRobots?.index && currentPage === 1,
    follow: blogListRobots?.follow,
  },
  openGraph: {
    type: 'blog',
  },
};
---

<Layout metadata={metadata}>
  <NeuralFlowHero
    kicker="WONDERLAND OS · /blog"
    title={`WonderLand <em>Notebook</em>`}
    subtitle="Research, AI, biology — and the strange tissue between them."
    subtitleZh="研究、AI、生命，以及它们之间那些奇异的组织。"
    terminalPath="~/blog"
  />

  <div class="nf-continue">
    <!-- synthwave grid continuation -->
    <div class="nf-grid-continue" aria-hidden="true"></div>
    <!-- CRT scanlines -->
    <div class="nf-crt" aria-hidden="true"></div>

    <!-- Fun & Curious Papers shelf promo -->
    <section class="nf-shelfwrap">
      <a href="/fun-pages/" class="nf-shelf">
        <div class="nf-shelf-label">
          <span class="dot"></span>
          <span>SHELF · 13 ENTRIES · CURATED</span>
        </div>
        <div class="nf-shelf-grid">
          <div class="nf-shelf-main">
            <h2 class="nf-shelf-title">Fun &amp; <em>Curious</em> Papers</h2>
            <p class="nf-shelf-sub">A separate room of the notebook — the papers I most enjoyed making, laid out like an editorial shelf. Brains &amp; speech, AI &amp; the world, vision &amp; the edges, and one small love game.</p>
            <div class="nf-shelf-tags">
              <span>Nat. Mach. Intell.</span>
              <span>PNAS</span>
              <span>Nat. Comm.</span>
              <span>arXiv ×8</span>
              <span>essay</span>
              <span>toy</span>
            </div>
          </div>
          <div class="nf-shelf-mini">
            <div class="nf-mini-card">
              <span class="no">01</span>
              <span class="ttl">Neural speech decoding</span>
              <span class="pg">NAT.MACH.INTELL</span>
            </div>
            <div class="nf-mini-card">
              <span class="no">02</span>
              <span class="ttl">AI &amp; systemic risk</span>
              <span class="pg">ARXIV · 26</span>
            </div>
            <div class="nf-mini-card">
              <span class="no">07</span>
              <span class="ttl">Subject-agnostic transformer</span>
              <span class="pg">NAT.COMM.</span>
            </div>
            <div class="nf-mini-card accent">
              <span class="no">13</span>
              <span class="ttl">MengMeng 2048</span>
              <span class="pg">INTERLUDE</span>
            </div>
          </div>
        </div>
        <div class="nf-shelf-cta">
          <span class="nf-shelf-cta-text">OPEN THE SHELF</span>
          <span class="nf-shelf-cta-arr">→</span>
        </div>
      </a>
    </section>

    <section class="nf-listwrap">
      <div class="nf-section-head">
        <span class="bar"></span>
        <span>LATEST · 最新</span>
        <span class="bar"></span>
      </div>
      <BlogList posts={page.data} />
      <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
    </section>
  </div>
</Layout>

<style is:global>
  /* ======== Cyberpunk continuation backdrop ======== */
  .nf-continue {
    background:
      radial-gradient(ellipse 60% 40% at 12% 4%, rgba(5, 217, 232, 0.12), transparent 60%),
      radial-gradient(ellipse 50% 45% at 90% 18%, rgba(255, 42, 109, 0.10), transparent 65%),
      radial-gradient(ellipse 60% 50% at 50% 80%, rgba(255, 42, 109, 0.08), transparent 70%),
      radial-gradient(ellipse 40% 30% at 85% 62%, rgba(5, 217, 232, 0.08), transparent 60%),
      linear-gradient(180deg, #05070f 0%, #07091a 50%, #05060f 100%);
    min-height: 70vh;
    position: relative;
    color: #d1fff0;
    overflow: hidden;
  }

  /* subtle synthwave grid */
  .nf-grid-continue {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background-image:
      linear-gradient(rgba(255, 42, 109, 0.07) 1px, transparent 1px),
      linear-gradient(90deg, rgba(5, 217, 232, 0.07) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 90% 100% at 50% 50%, #000, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 90% 100% at 50% 50%, #000, transparent 70%);
    opacity: 0.7;
  }

  /* CRT scanlines */
  .nf-crt {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background-image: repeating-linear-gradient(0deg, rgba(5, 217, 232, 0.045) 0 1px, transparent 1px 4px);
    opacity: 0.6;
  }

  .nf-listwrap,
  .nf-shelfwrap {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    padding: 56px 24px 0;
  }
  .nf-listwrap { padding: 32px 24px 96px; }

  .nf-section-head {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.28em;
    color: rgba(5, 217, 232, 0.65);
    text-transform: uppercase;
    margin-bottom: 40px;
  }
  .nf-section-head .bar {
    flex: 1;
    max-width: 120px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(5, 217, 232, 0.45), transparent);
  }

  /* ======== FUN PAPERS SHELF ======== */
  .nf-shelf {
    display: block;
    text-decoration: none;
    color: inherit;
    position: relative;
    border: 1px solid rgba(5, 217, 232, 0.3);
    background:
      linear-gradient(180deg, rgba(5, 217, 232, 0.03), rgba(255, 42, 109, 0.03)),
      rgba(5, 5, 11, 0.5);
    backdrop-filter: blur(4px);
    padding: 28px 28px 22px;
    transition: all 0.25s;
    overflow: hidden;
  }
  .nf-shelf::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 14px; height: 14px;
    border-top: 1px solid #05d9e8;
    border-left: 1px solid #05d9e8;
  }
  .nf-shelf::after {
    content: '';
    position: absolute;
    bottom: 0; right: 0;
    width: 14px; height: 14px;
    border-bottom: 1px solid #ff2a6d;
    border-right: 1px solid #ff2a6d;
  }
  .nf-shelf:hover {
    border-color: #05d9e8;
    box-shadow: 0 0 40px rgba(5, 217, 232, 0.2), 4px 4px 0 rgba(255, 42, 109, 0.4);
    transform: translate(-2px, -2px);
  }
  .nf-shelf-label {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.26em;
    color: rgba(5, 217, 232, 0.75);
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .nf-shelf-label .dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #05d9e8;
    box-shadow: 0 0 8px #05d9e8;
  }
  .nf-shelf-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 28px;
    align-items: start;
  }
  .nf-shelf-title {
    font-family: 'Instrument Serif', serif;
    font-weight: 400;
    font-size: clamp(32px, 4.6vw, 52px);
    line-height: 0.98;
    letter-spacing: -0.02em;
    margin: 0 0 12px 0;
    color: #f1f5ff;
  }
  .nf-shelf-title em {
    font-style: italic;
    background: linear-gradient(90deg, #ff2bd6, #ffea3a, #4dc5ff);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: cyGrad2 6s linear infinite;
  }
  @keyframes cyGrad2 { 0%{background-position:0 0} 100%{background-position:200% 0} }
  .nf-shelf-sub {
    font-family: 'Instrument Serif', serif;
    font-style: italic;
    font-size: 16px;
    line-height: 1.55;
    color: rgba(209, 255, 240, 0.7);
    margin: 0 0 14px 0;
  }
  .nf-shelf-tags {
    display: flex; flex-wrap: wrap; gap: 6px;
  }
  .nf-shelf-tags span {
    display: inline-block;
    padding: 3px 8px;
    border: 1px solid rgba(5, 217, 232, 0.25);
    background: rgba(5, 217, 232, 0.04);
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.14em;
    color: rgba(5, 217, 232, 0.8);
    text-transform: uppercase;
  }
  .nf-shelf-mini { display: grid; gap: 6px; }
  .nf-mini-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 10px;
    align-items: baseline;
    padding: 8px 10px;
    border: 1px solid rgba(5, 217, 232, 0.15);
    background: rgba(5, 5, 11, 0.4);
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    transition: all 0.2s;
  }
  .nf-mini-card .no {
    color: rgba(5, 217, 232, 0.55);
    font-size: 9px;
    letter-spacing: 0.14em;
  }
  .nf-mini-card .ttl {
    color: #d1fff0;
    font-family: 'Instrument Serif', serif;
    font-size: 14px;
    font-style: italic;
  }
  .nf-mini-card .pg {
    color: rgba(5, 217, 232, 0.55);
    font-size: 8.5px;
    letter-spacing: 0.16em;
  }
  .nf-mini-card.accent {
    border-color: rgba(255, 42, 109, 0.35);
    background: rgba(255, 42, 109, 0.05);
  }
  .nf-mini-card.accent .no,
  .nf-mini-card.accent .pg { color: rgba(255, 42, 109, 0.8); }
  .nf-shelf:hover .nf-mini-card { border-color: rgba(5, 217, 232, 0.35); }

  .nf-shelf-cta {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 10px;
    margin-top: 22px;
    padding-top: 18px;
    border-top: 1px dashed rgba(5, 217, 232, 0.22);
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.26em;
    color: #05d9e8;
    text-transform: uppercase;
  }
  .nf-shelf-cta-arr { transition: transform 0.25s; font-size: 16px; }
  .nf-shelf:hover .nf-shelf-cta-arr { transform: translateX(6px); }

  @media (max-width: 720px) {
    .nf-shelf-grid { grid-template-columns: 1fr; }
  }

  /* ======== Nuke AstroWind ListItem card ======== */
  .nf-continue article {
    display: block !important;
    max-width: none !important;
    margin: 0 !important;
    padding: 0 !important;
    background: transparent !important;
  }
  .nf-continue article > div {
    background: transparent !important;
    border: 0 !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    padding: 0 !important;
    margin: 0 !important;
    transition: none !important;
  }
  .nf-continue article > a,
  .nf-continue article > div.relative {
    display: none !important;
  }
  .nf-continue article.md\:grid-cols-2 {
    grid-template-columns: none !important;
  }

  /* ======== Editorial rows in cyberpunk palette ======== */
  .nf-continue ul { padding: 0; list-style: none; }
  .nf-continue ul > li {
    margin: 0 !important;
    padding: 36px 0 !important;
    border-bottom: 1px solid rgba(5, 217, 232, 0.1);
    transition: padding 0.3s;
  }
  .nf-continue ul > li:first-child { padding-top: 0 !important; }
  .nf-continue ul > li:last-child { border-bottom: none; }
  .nf-continue ul > li:hover { padding-left: 8px !important; }

  /* meta line (date · author · category) */
  .nf-continue article header .mb-1 {
    font-family: 'JetBrains Mono', ui-monospace, monospace !important;
    font-size: 10px !important;
    letter-spacing: 0.22em !important;
    text-transform: uppercase !important;
    margin-bottom: 14px !important;
  }
  .nf-continue article header .mb-1 span,
  .nf-continue article header .mb-1 time {
    color: rgba(180, 220, 230, 0.7) !important;
    font-size: 10px !important;
  }
  .nf-continue article header .mb-1 a {
    color: #ff2a6d !important;
    text-decoration: none !important;
    border-bottom: 1px dotted rgba(255, 42, 109, 0.45) !important;
    padding-bottom: 1px;
  }
  .nf-continue article header .mb-1 a:hover {
    color: #ff5a90 !important;
    border-bottom-color: #ff5a90 !important;
  }
  .nf-continue article header .mb-1 svg {
    color: rgba(5, 217, 232, 0.5) !important;
  }

  /* post title — big serif with cyan glow */
  .nf-continue article h2 {
    font-family: 'Instrument Serif', 'Times New Roman', serif !important;
    font-weight: 400 !important;
    font-size: clamp(26px, 3.2vw, 40px) !important;
    line-height: 1.1 !important;
    letter-spacing: -0.015em !important;
    margin: 0 0 14px 0 !important;
    color: #f1f5ff !important;
  }
  .nf-continue article h2 a {
    color: inherit !important;
    text-decoration: none !important;
    transition: color 0.25s, text-shadow 0.25s !important;
    background: none !important;
  }
  .nf-continue article h2 a:hover {
    color: #9fe8ff !important;
    text-shadow: 0 0 18px rgba(5, 217, 232, 0.5);
  }
  .nf-continue article h2 .text-amber-600,
  .nf-continue article h2 [class*='amber'] {
    color: #ffe066 !important;
  }

  /* excerpt — italic serif */
  .nf-continue article p {
    font-family: 'Instrument Serif', 'Times New Roman', serif !important;
    font-style: italic !important;
    font-size: 18px !important;
    line-height: 1.6 !important;
    color: rgba(209, 255, 240, 0.72) !important;
    margin: 0 !important;
    max-width: 64ch;
  }

  /* tags — clipped-corner chips like homepage nav buttons */
  .nf-continue article footer {
    margin-top: 16px !important;
  }
  .nf-continue article footer ul {
    display: flex !important;
    flex-wrap: wrap;
    gap: 6px !important;
    padding: 0 !important;
  }
  .nf-continue article footer ul li {
    margin: 0 !important;
    padding: 0 !important;
    border: 0 !important;
  }
  .nf-continue article footer ul li a,
  .nf-continue article footer span {
    display: inline-block !important;
    padding: 4px 10px !important;
    border: 1px solid rgba(5, 217, 232, 0.25) !important;
    background: rgba(5, 217, 232, 0.04) !important;
    font-family: 'JetBrains Mono', ui-monospace, monospace !important;
    font-size: 10px !important;
    letter-spacing: 0.14em !important;
    text-transform: lowercase !important;
    color: rgba(5, 217, 232, 0.8) !important;
    text-decoration: none !important;
    transition: all 0.15s !important;
    border-radius: 0 !important;
  }
  .nf-continue article footer ul li a:hover {
    color: #05050b !important;
    background: #05d9e8 !important;
    border-color: #05d9e8 !important;
    clip-path: polygon(0 0, calc(100% - 6px) 0, 100% 6px, 100% 100%, 6px 100%, 0 calc(100% - 6px)) !important;
    box-shadow: 3px 3px 0 #ff2a6d !important;
    transform: translate(-1px, -1px);
  }

  /* pagination */
  .nf-continue nav[aria-label*='aginat'],
  .nf-continue .pagination {
    margin-top: 56px !important;
    padding-top: 32px !important;
    border-top: 1px solid rgba(5, 217, 232, 0.15) !important;
  }
  .nf-continue nav a,
  .nf-continue .pagination a {
    color: rgba(5, 217, 232, 0.8) !important;
    font-family: 'JetBrains Mono', monospace !important;
    font-size: 11px !important;
    letter-spacing: 0.2em !important;
    text-transform: uppercase !important;
  }
  .nf-continue nav a:hover,
  .nf-continue .pagination a:hover {
    color: #9fe8ff !important;
  }

  @media (max-width: 640px) {
    .nf-listwrap { padding: 32px 18px 64px; }
    .nf-shelfwrap { padding: 40px 18px 0; }
    .nf-continue ul > li { padding: 28px 0 !important; }
    .nf-continue article h2 { font-size: 24px !important; }
    .nf-continue article p { font-size: 16px !important; }
  }
</style>
